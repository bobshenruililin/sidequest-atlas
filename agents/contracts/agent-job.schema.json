{
  "$ref": "#/definitions/AgentJob",
  "definitions": {
    "AgentJob": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "1.0.0"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tripSlug": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "enum": [
            "intake",
            "research",
            "synthesize",
            "validate",
            "revise",
            "publish",
            "archive",
            "capture",
            "journal"
          ]
        },
        "requestedAt": {
          "type": "string"
        },
        "requestedBy": {
          "type": "string"
        },
        "inputHash": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "awaiting-review",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "maximumAttempts": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "lockedBy": {
          "type": "string"
        },
        "lockedAt": {
          "type": "string"
        },
        "completedAt": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "id",
        "tripSlug",
        "operation",
        "requestedAt",
        "requestedBy",
        "inputHash",
        "status",
        "attempt",
        "maximumAttempts"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
