{
  "$ref": "#/definitions/Claim",
  "definitions": {
    "Claim": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "subjectType": {
          "type": "string",
          "enum": [
            "event",
            "venue",
            "price",
            "schedule",
            "transport",
            "institution",
            "economic-statistic",
            "company-strategy"
          ]
        },
        "subjectId": {
          "type": "string",
          "minLength": 1
        },
        "fieldPath": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "traveler-provided",
            "researched",
            "inferred",
            "unverified",
            "superseded"
          ]
        },
        "sourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "verifiedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "validFrom": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "validUntil": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reverifyAfter": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "subjectType",
        "subjectId",
        "fieldPath",
        "statement",
        "status",
        "confidence"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
