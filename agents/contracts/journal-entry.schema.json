{
  "$ref": "#/definitions/JournalEntry",
  "definitions": {
    "JournalEntry": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "1.0.0"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-\\d{4}-\\d{2}-\\d{2}$"
        },
        "tripSlug": {
          "type": "string",
          "minLength": 1
        },
        "localDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "timeZone": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "type": "string",
          "const": "vault",
          "default": "vault"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "reflected",
            "closed"
          ],
          "default": "open"
        },
        "revision": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "fragments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "recordedAt": {
                "type": "string",
                "format": "date-time"
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "prompt": {
                "type": "string",
                "enum": [
                  "surprise",
                  "ordinary-life",
                  "tomorrow",
                  "free"
                ]
              },
              "respondsTo": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            },
            "required": [
              "id",
              "recordedAt",
              "text"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "reflections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "reflectedAt": {
                "type": "string",
                "format": "date-time"
              },
              "depth": {
                "type": "string",
                "enum": [
                  "quick",
                  "deep"
                ]
              },
              "sourceRevision": {
                "type": "integer",
                "minimum": 0
              },
              "sourceDigest": {
                "type": "string",
                "minLength": 1
              },
              "insights": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "noticed",
                        "interpretation",
                        "hypothesis",
                        "contradiction",
                        "question"
                      ]
                    },
                    "text": {
                      "type": "string",
                      "minLength": 1
                    },
                    "evidenceFragmentIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "minItems": 1
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    }
                  },
                  "required": [
                    "id",
                    "kind",
                    "text",
                    "evidenceFragmentIds",
                    "confidence"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "challenge": {
                "type": "string"
              },
              "bounceQuestion": {
                "type": "string"
              },
              "candidates": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "observation"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "dayId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "category": {
                          "type": "string",
                          "enum": [
                            "food",
                            "labor",
                            "transport",
                            "design",
                            "trust",
                            "wealth",
                            "education",
                            "technology",
                            "behavior",
                            "contradiction",
                            "personal"
                          ]
                        },
                        "text": {
                          "type": "string",
                          "minLength": 1
                        },
                        "certainty": {
                          "type": "string",
                          "enum": [
                            "noticed",
                            "interpreted",
                            "hypothesis"
                          ],
                          "default": "noticed"
                        },
                        "evidenceFragmentIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "default": []
                        }
                      },
                      "required": [
                        "kind",
                        "id",
                        "dayId",
                        "category",
                        "text"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "decision"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "decisionId": {
                          "type": "string",
                          "minLength": 1
                        },
                        "action": {
                          "type": "string",
                          "enum": [
                            "consider",
                            "select",
                            "reopen",
                            "record-outcome"
                          ]
                        },
                        "optionId": {
                          "type": "string"
                        },
                        "note": {
                          "type": "string",
                          "minLength": 1
                        },
                        "evidenceFragmentIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "default": []
                        }
                      },
                      "required": [
                        "kind",
                        "id",
                        "decisionId",
                        "action",
                        "note"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "capture"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "title": {
                          "type": "string",
                          "minLength": 1
                        },
                        "rawText": {
                          "type": "string",
                          "minLength": 1
                        },
                        "spark": {
                          "type": "string"
                        },
                        "domains": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "career",
                              "travel",
                              "opportunity",
                              "research",
                              "capital",
                              "relationship",
                              "idea",
                              "health",
                              "other"
                            ]
                          },
                          "minItems": 1
                        },
                        "ask": {
                          "type": "string",
                          "enum": [
                            "use",
                            "defer",
                            "ignore",
                            "synthesize",
                            "investigate"
                          ],
                          "default": "investigate"
                        },
                        "evidenceFragmentIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "default": []
                        }
                      },
                      "required": [
                        "kind",
                        "id",
                        "title",
                        "rawText",
                        "domains"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": {
                          "type": "string",
                          "const": "canon-insight"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "statement": {
                          "type": "string",
                          "minLength": 1
                        },
                        "rationale": {
                          "type": "string",
                          "minLength": 1
                        },
                        "evidenceFragmentIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "default": []
                        }
                      },
                      "required": [
                        "kind",
                        "id",
                        "statement",
                        "rationale"
                      ],
                      "additionalProperties": false
                    }
                  ]
                },
                "default": []
              }
            },
            "required": [
              "id",
              "reflectedAt",
              "depth",
              "sourceRevision",
              "sourceDigest"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "promotions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "candidateId": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "enum": [
                  "observation",
                  "decision",
                  "capture",
                  "canon-insight"
                ]
              },
              "promotedAt": {
                "type": "string",
                "format": "date-time"
              },
              "destinationId": {
                "type": "string",
                "minLength": 1
              },
              "destinationPath": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "candidateId",
              "kind",
              "promotedAt",
              "destinationId",
              "destinationPath"
            ],
            "additionalProperties": false
          },
          "default": []
        }
      },
      "required": [
        "id",
        "tripSlug",
        "localDate",
        "timeZone",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
