{
  "$ref": "#/definitions/SourceRecord",
  "definitions": {
    "SourceRecord": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "publishedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "accessedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "official",
            "primary",
            "academic",
            "government",
            "reputable-secondary",
            "community"
          ]
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "reverifyAfter": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "required": [
        "id",
        "title",
        "publisher",
        "url",
        "accessedAt",
        "sourceType",
        "confidence"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
