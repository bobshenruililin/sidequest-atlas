{
  "name": "@sidequest-atlas/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "atlas": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sidequest-atlas/content": "0.1.0",
    "@sidequest-atlas/domain": "0.1.0",
    "@sidequest-atlas/exporters": "0.1.0",
    "@sidequest-atlas/intelligence": "0.1.0",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
